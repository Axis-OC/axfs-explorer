<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AxfsExplorer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AxfsExplorer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppCardHover" Color="{ThemeResource SubtleFillColorSecondary}"/>

            <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="1,28,0,8"/>
                <Setter Property="Opacity" Value="0.50"/>
                <Setter Property="CharacterSpacing" Value="60"/>
            </Style>

            <Style x:Key="MuteButton" TargetType="Button">
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="MinWidth" Value="32"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>

            <!-- ══════ TAB STRIP: Fix the focused/selected tab colors ══════ -->
            <!-- Override the NavigationView's top-mode selected indicator to use accent -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#FF7C5CE7"/>

            <!-- ══════ ACCENT PALETTE ══════ -->

            <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#FF7C5CE7" Offset="0.0"/>
                <GradientStop Color="#FF3B82F6" Offset="0.45"/>
                <GradientStop Color="#FF06B6D4" Offset="0.75"/>
                <GradientStop Color="#FF34D399" Offset="1.0"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="AccentGradientVertical" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1A7C5CE7" Offset="0.0"/>
                <GradientStop Color="#00000000" Offset="1.0"/>
            </LinearGradientBrush>

            <!-- Sidebar subtle gradient -->
            <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#08FFFFFF" Offset="0.0"/>
                <GradientStop Color="#00000000" Offset="0.4"/>
                <GradientStop Color="#04000000" Offset="1.0"/>
            </LinearGradientBrush>

            <!-- File type color brushes -->
            <SolidColorBrush x:Key="FileIconLua" Color="#FF60A5FA"/>
            <SolidColorBrush x:Key="FileIconConfig" Color="#FFFBBF24"/>
            <SolidColorBrush x:Key="FileIconText" Color="#FF34D399"/>
            <SolidColorBrush x:Key="FileIconLog" Color="#FFC084FC"/>
            <SolidColorBrush x:Key="FileIconSig" Color="#FFEF4444"/>
            <SolidColorBrush x:Key="FileIconFolder" Color="#FFFBBF24"/>
            <SolidColorBrush x:Key="FileIconDefault" Color="#FF94A3B8"/>

            <!-- Badge styles -->
            <Style x:Key="StatBadge" TargetType="Border">
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="10,4,10,4"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
            </Style>

            <Style x:Key="GlassCard" TargetType="Border">
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="16,14"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- Search box style -->
            <Style x:Key="FilterBox" TargetType="TextBox">
                <Setter Property="MinWidth" Value="200"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="8,4"/>
            </Style>

            <!-- ══════ SETTINGS CARD STYLE ══════ -->
            <Style x:Key="SettingsCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="Padding" Value="20,16"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            </Style>
            <!-- Command palette -->
            <Style x:Key="CmdPaletteItem" TargetType="ListViewItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
            </Style>

            <!-- Health status colors -->
            <SolidColorBrush x:Key="HealthGreen" Color="#FF34D399"/>
            <SolidColorBrush x:Key="HealthRed" Color="#FFEF4444"/>
            <SolidColorBrush x:Key="HealthYellow" Color="#FFFBBF24"/>

            <!-- Sort header button -->
            <Style x:Key="SortHeaderBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>